# Server
SITEHUB_HOST=0.0.0.0
SITEHUB_PORT=3000
# Base domain for subdomain-based tenant identification.
# Tenants are resolved as {tenant}.{base_domain} (e.g., mg-geo-milev.sitehub.localhost).
SITEHUB_BASE_DOMAIN=sitehub.localhost

# SurrealDB
SURREAL_URL=ws://localhost:8000
SURREAL_NS=sitehub
SURREAL_DB=main
# Must match the credentials in docker-compose.yml
SURREAL_USER=root
SURREAL_PASS=root

# JWT
# IMPORTANT: change this in production — do not deploy with the dev default.
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_TOKEN_TTL_SECS=900       # 15 minutes
JWT_REFRESH_TOKEN_TTL_SECS=604800   # 7 days

# Logging (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=info,sitehub=debug
